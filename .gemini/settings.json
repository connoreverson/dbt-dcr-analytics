{
  "context": {
    "importFormat": "@",
    "fileFiltering": {
      "respectGitIgnore": true,
      "respectGeminiIgnore": true,
      "enableRecursiveFileSearch": true
    },
    "includeDirectories": [
      "reference",
      "source_data",
      ".agent"
    ],
    "loadFromIncludeDirectories": false
  },
  "tools": {
    "shell": {
      "enableInteractiveShell": false
    }
  },
  "general": {
    "checkpointing": {
      "enabled": true
    }
  },
  "permissions": {
    "allow": [
      "PowerShell(*git add*)",
      "PowerShell(*git commit*)",
      "PowerShell(*dbt build*)",
      "PowerShell(*dbt show*)",
      "PowerShell(*dbt list*)",
      "PowerShell(*dbt test*)",
      "PowerShell(*dbt run*)",
      "PowerShell(*dbt seed*)",
      "PowerShell(*dbt deps*)",
      "PowerShell(*dbt source*)",
      "PowerShell(*dbt compile*)",
      "PowerShell(*sqlfluff lint*)",
      "PowerShell(*sqlfluff fix*)",
      "PowerShell(*python scripts/check_model.py*)",
      "PowerShell(*python scripts/review_model.py*)",
      "PowerShell(*python scripts/parse_standards.py*)",
      "PowerShell(*pip install -r requirements.txt*)",
      "PowerShell(*dbt debug*)",
      "PowerShell(*dbt ls*)",
      "PowerShell(*dbt run-operation*)"
    ],
    "deny": [
      "PowerShell(rm -rf:*)",
      "PowerShell(rm -r:*)",
      "PowerShell(pip install:*)",
      "Write(reference/business_artifacts/*)",
      "Edit(reference/business_artifacts/*)",
      "Write(requirements.txt)",
      "Edit(requirements.txt)"
    ]
  }
}